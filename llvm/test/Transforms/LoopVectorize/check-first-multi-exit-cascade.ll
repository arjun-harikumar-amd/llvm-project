; Two unguarded early exits plus a counted latch exit. Check-first builds a
; cascade of check blocks evaluated in source order: vector.body (check.0) tests
; exit 0 and, if no lane fires, falls through to vector.check (check.1) which
; tests exit 1; only if both pass does vector.body4 (the stores) execute. Either
; exit firing short-circuits to vector.check.exit -> scalar.ph, which replays the
; failing chunk from its start index.

@A = global [1024 x i32] zeroinitializer
@B = global [1024 x i32] zeroinitializer
@D = global [1024 x i32] zeroinitializer

define i32 @multi_exit_cascade() {
; CHECK-LABEL: define i32 @multi_exit_cascade() {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    br label %[[VECTOR_PH:.*]]
; CHECK:       [[VECTOR_PH]]:
; CHECK-NEXT:    br label %[[VECTOR_BODY:.*]]
; CHECK:       [[VECTOR_BODY]]:
; CHECK-NEXT:    [[INDEX:%.*]] = phi i64 [ 0, %[[VECTOR_PH]] ], [ [[INDEX_NEXT:%.*]], %[[VECTOR_BODY4:.*]] ]
; CHECK-NEXT:    [[TMP0:%.*]] = add i64 [[INDEX]], 1
; CHECK-NEXT:    [[TMP1:%.*]] = add i64 [[INDEX]], 2
; CHECK-NEXT:    [[TMP2:%.*]] = add i64 [[INDEX]], 3
; CHECK-NEXT:    [[TMP3:%.*]] = getelementptr inbounds [1024 x i32], ptr @A, i64 0, i64 [[INDEX]]
; CHECK-NEXT:    [[WIDE_LOAD:%.*]] = load <4 x i32>, ptr [[TMP3]], align 4
; CHECK-NEXT:    [[TMP4:%.*]] = icmp eq <4 x i32> [[WIDE_LOAD]], zeroinitializer
; CHECK-NEXT:    [[TMP5:%.*]] = getelementptr inbounds [1024 x i32], ptr @B, i64 0, i64 [[INDEX]]
; CHECK-NEXT:    [[WIDE_LOAD3:%.*]] = load <4 x i32>, ptr [[TMP5]], align 4
; CHECK-NEXT:    [[TMP6:%.*]] = icmp eq <4 x i32> [[WIDE_LOAD3]], zeroinitializer
; CHECK-NEXT:    [[TMP7:%.*]] = freeze <4 x i1> [[TMP4]]
; CHECK-NEXT:    [[TMP8:%.*]] = call i1 @llvm.vector.reduce.or.v4i1(<4 x i1> [[TMP7]])
; CHECK-NEXT:    br i1 [[TMP8]], label %[[VECTOR_CHECK_EXIT:.*]], label %[[VECTOR_CHECK:.*]]
; CHECK:       [[VECTOR_CHECK]]:
; CHECK-NEXT:    [[TMP9:%.*]] = freeze <4 x i1> [[TMP6]]
; CHECK-NEXT:    [[TMP10:%.*]] = call i1 @llvm.vector.reduce.or.v4i1(<4 x i1> [[TMP9]])
; CHECK-NEXT:    br i1 [[TMP10]], label %[[VECTOR_CHECK_EXIT]], label %[[VECTOR_BODY4]]
; CHECK:       [[VECTOR_BODY4]]:
; CHECK-NEXT:    [[TMP11:%.*]] = add <4 x i32> [[WIDE_LOAD]], [[WIDE_LOAD3]]
; CHECK-NEXT:    [[TMP12:%.*]] = getelementptr inbounds [1024 x i32], ptr @D, i64 0, i64 [[INDEX]]
