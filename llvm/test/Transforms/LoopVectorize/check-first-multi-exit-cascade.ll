; CHECK-NEXT:    [[GA:%.*]] = getelementptr inbounds [1024 x i32], ptr @A, i64 0, i64 [[IV]]
; CHECK-NEXT:    [[LA:%.*]] = load i32, ptr [[GA]], align 4
